DATABASE_URL=postgres://forgequeue:forgequeue@localhost:5432/forgequeue
BIND_ADDRESS=0.0.0.0:8080
# Sólo para el rol worker; cada proceso necesita un puerto distinto en el host.
# WORKER_METRICS_ADDRESS=0.0.0.0:9091
CORS_ORIGIN=http://localhost:5173
TRUST_PROXY_HEADERS=false
RATE_LIMIT_SALT=replace-with-a-random-secret

# Desarrollo directo en el host
OBJECT_STORE_URL=file:///
OBJECT_STORE_PATH=./data

# Docker Compose / Supabase S3
# OBJECT_STORE_URL=s3://forgequeue
# S3_ENDPOINT=http://localhost:9000
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=forgequeue
# S3_SECRET_ACCESS_KEY=forgequeue-secret

MAX_UPLOAD_BYTES=10485760
MAX_IMAGE_PIXELS=25000000
MAX_PDF_PAGES=20
PDF_PREVIEW_PAGES=3
LEASE_SECONDS=60
HEARTBEAT_SECONDS=15
PROCESSING_TIMEOUT_SECONDS=90
WORKER_POLL_MILLISECONDS=750
DEMO_PROCESSING_DELAY_MILLISECONDS=0
ARTIFACT_RETENTION_SECONDS=3600
METADATA_RETENTION_SECONDS=86400
